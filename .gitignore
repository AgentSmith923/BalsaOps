# Live data — never commit real business data to source control.
data/balsa.db
data/balsa.db-shm
data/balsa.db-wal
data/backups/

# Uploaded attachments — user files, not code.
uploads/*
!uploads/.gitkeep

# Node dependencies — regenerated by "npm install", no need to track them.
node_modules/
package-lock.json

# C# desktop app build output — regenerated by Visual Studio.
BalsaOpsDesktop/bin/
BalsaOpsDesktop/obj/

# OS junk files.
.DS_Store
Thumbs.db
